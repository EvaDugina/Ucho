# Telegram bot token из @BotFather
TELEGRAM_BOT_TOKEN=

# Твой Telegram user_id (узнать у @userinfobot). Все остальные — игнорируются.
OWNER_TELEGRAM_ID=

# Час по UTC, когда бот сам пришлёт дневной вопрос (0-23).
DAILY_HOUR=18

# OpenRouter live-модели.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
LLM_MODEL_DEFAULT=qwen/qwen3-235b-a22b-2507
LLM_MODEL_FALLBACKS=deepseek/deepseek-v4-flash
OPENROUTER_DATA_COLLECTION=deny
OPENROUTER_ZDR=true
LLM_TIMEOUT=90
LLM_COOLDOWN_SEC=4
ANALYSIS_ENABLED=true

# Путь к папке вольта на ХОСТЕ — docker-compose монтирует её в /vault.
# Меняй здесь, если переносишь базу. Слэши Unix-стиля (даже на Windows).
VAULT_HOST_PATH=

# Путь к папке вольта ВНУТРИ контейнера. Не меняй без необходимости.
VAULT_PATH=/vault
