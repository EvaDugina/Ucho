# Telegram bot token из @BotFather
TELEGRAM_BOT_TOKEN=

# Твой Telegram user_id (узнать у @userinfobot). Все остальные — игнорируются.
OWNER_TELEGRAM_ID=

# Час по UTC, когда бот сам пришлёт дневной вопрос (0-23).
DAILY_HOUR=20

# Локальная LLM через Ollama. Не меняй, если не понимаешь что делаешь.
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:14b-instruct

# Путь к папке вольта на ХОСТЕ — docker-compose монтирует её в /vault.
# Меняй здесь, если переносишь базу. Слэши Unix-стиля (даже на Windows).
VAULT_HOST_PATH=C:/Users/eva/YandexDisk/Obsidian/Psycho

# Путь к папке вольта ВНУТРИ контейнера. Не меняй без необходимости.
VAULT_PATH=/vault
