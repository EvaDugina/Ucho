# Telegram bot token из @BotFather
TELEGRAM_BOT_TOKEN=

# Твой Telegram user_id (узнать у @userinfobot). Все остальные — игнорируются.
OWNER_TELEGRAM_ID=

# Час в DAILY_TZ, когда бот сам пришлёт дневной вопрос (0-23).
DAILY_HOUR=18

# Live-LLM provider.
# Если OPENROUTER_API_KEY непустой, бот использует OpenRouter с приоритетом.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DEFAULT=qwen/qwen3-235b-a22b-2507
OPENROUTER_MODEL_FALLBACKS=deepseek/deepseek-v4-flash
OPENROUTER_MODEL_FAST=deepseek/deepseek-v4-flash
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Ucho

# Fallback provider: AITunnel, если OPENROUTER_API_KEY пустой.
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
LLM_MODEL_DEFAULT=qwen3-235b-a22b-2507
LLM_MODEL_FALLBACKS=deepseek-v4-flash
LLM_MODEL_FAST=deepseek-v4-flash
LLM_TIMEOUT=90
LLM_COOLDOWN_SEC=4
ANALYSIS_ENABLED=true

# Путь к папке вольта на ХОСТЕ — docker-compose монтирует её в /vault.
# Меняй здесь, если переносишь базу. Слэши Unix-стиля (даже на Windows).
VAULT_HOST_PATH=

# Путь к папке вольта ВНУТРИ контейнера. Не меняй без необходимости.
VAULT_PATH=/vault
